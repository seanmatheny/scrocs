<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.scrocs.sync</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/YOU/.local/share/scrocs/bin/scrocs</string>
    </array>

    <!-- Provide Homebrew paths so libusb is found at runtime and osascript
         works as expected when the agent is started by launchd. -->
    <key>EnvironmentVariables</key>
    <dict>
      <key>PATH</key>
      <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
      <key>DYLD_LIBRARY_PATH</key>
      <string>/usr/local/lib:/opt/homebrew/lib</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>StandardOutPath</key>
    <string>/Users/YOU/Library/Logs/scrocs-launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/YOU/Library/Logs/scrocs-launchd.log</string>
  </dict>
</plist>
